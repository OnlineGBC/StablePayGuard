# AI providers (at least one required for payment intent generation)
SYNTH_API_KEY=sk-synth-your-hackathon-key-here
OPENAI_API_KEY=your_openai_api_key_here

# Flask
FLASK_ENV=development
PORT=5000
SECRET_KEY=change-me-to-a-random-secret
ADMIN_PASSWORD=demo

# Database — comment out or omit for SQLite (default local fallback, no setup needed)
# DATABASE_URL=postgresql://stablepayguard:stablepayguard@localhost:5432/stablepayguard

# Blockchain / deployment
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
PRIVATE_KEY=your_deployer_wallet_private_key
POLICY_CONTRACT=0xDeployedContractAddressHere
OWNER_WALLET=0xYourWalletAddress
